# DeepField Environment Configuration
DATABASE_URL=postgresql://deepfield:changeme@localhost:5432/deepfield
DB_RETENTION_DAYS=7

# LiteLLM inference proxy
LITELLM_API_BASE=
LITELLM_API_KEY=

# Cluster monitoring (up to 20 clusters)
CLUSTER_1_NAME=
CLUSTER_1_API_URL=
CLUSTER_1_TOKEN=
CLUSTER_1_INCLUDE_NS=*
CLUSTER_1_EXCLUDE_NS=openshift-*,kube-*

# Splunk integration (up to 5 instances)
SPLUNK_1_NAME=
SPLUNK_1_URL=
SPLUNK_1_USERNAME=
SPLUNK_1_PASSWORD=
SPLUNK_1_POLL_INTERVAL=120
SPLUNK_1_INDEXES=*

# Prometheus/Thanos (GPU metrics)
THANOS_URL=
SSL_VERIFY=false
